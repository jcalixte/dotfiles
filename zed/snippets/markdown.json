    "description": "The too long book title The field guide of understanding 'human errors'"
  },
  "Capture": {
    "prefix": "capture",
    "body": [
      "# ${1:Titre}",
      "",
      "## La capture de l'inspiration",
      "",
      "${2}",
      ""
    ]
  },
  "Pensée": {
    "prefix": "note",
    "body": ["> [!NOTE] ${1}", "> ${2}"]
  },
  "Conseil": {
    "prefix": "conseil",
    "body": ["> [!TIP] ${1}", "> ${2}"]
  },
  "Important": {
    "prefix": "important",
    "body": ["> [!IMPORTANT] ${1}", "> ${2}"]
  },
