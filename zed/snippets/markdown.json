  },
  "5W1H": {
    "prefix": "5w1h",
    "body": [
      "| Question | Réponse |",
      "|-|-|",
      "| Pourquoi | ${1:} |",
      "| Quoi | ${2:} |",
      "| Qui | ${3:} |",
      "| Quand | ${4:} |",
      "| Où | ${5:} |",
      "| Comment | ${6:} |"
    ]
  },
  "Mermaid graph": {
    "prefix": "graph",
    "body": ["```mermaid", "${1}", "```"],
    "description": "Mermaid diagram syntax"
  },
  "Première de couverture": {
    "prefix": "couverture",
    "body": "![Première de couverture](${1})"
  },
  "Short link": {
    "prefix": "shortlink",
    "body": ["---", "layout: forward", "target: $1", "---", ""],
    "description": "Create a short link template"
  }
