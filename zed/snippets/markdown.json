{
  "Todo": {
    "prefix": "todo",
    "body": "- [ ] ",
    "description": "Make a todo item"
  },
  "Bloc de références": {
    "prefix": "reference",
    "body": ["___", "", "## Références", ""],
    "description": "Adding a reference block"
  },
  "Bloc de références en anglais": {
    "prefix": "refangl",
    "body": ["___", "", "## References", ""],
    "description": "Adding a reference block in English"
  },
  "Idée de notes permanentes": {
    "prefix": "ideenote",
    "body": ["___", "", "## Idées de note permanente", ""],
    "description": "Idées de notes permanentes"
  },
  "Table traduction for French and Korean": {
    "prefix": "traduction",
    "body": ["| Français | Coréen |", "|-|-|", "| "],
    "description": "Table traduction for French and Korean"
  },
  "Table": {
    "prefix": "table",
    "body": ["| ${1} | ${2} |", "|-|-|", "| ${3} | ${4} |"],
    "description": "Table"
  },
  "Youtube integration": {
    "prefix": "youtube",
    "body": ["@[youtube](${1})", "", "- ${2} | ${3}", ""],
    "description": "Youtube integration"
  },
  "Twitter integration": {
    "prefix": "tweet",
    "body": ["@[tweet](${1})", "", "- ${2} | ${3}", ""],
    "description": "Twitter integration"
  },
  "Standard": {
    "prefix": "standard",
    "body": [
      "# ${1:Standard}",
      "",
      "## Points clefs",
      "",
      "## Erreurs à éviter",
      "",
      "___",
      "",
      "## Exemples",
      "",
      "___",
      "",
      "## Références"
    ],
    "description": "Standard"
  },
  "fiche de lecture": {
    "prefix": "fiche",
    "body": [
      "# 📘 ${1:Titre}",
      "",
      "## ${2:Auteur} - ${3:année}",
      "",
      "## De quoi traite le livre",
      ""
    ],
    "description": "Fiche de lecture"
  },
  "createur": {
    "prefix": "createur",
    "body": [
      "# 🖋️ ${1:Créateur}",
      "",
      "## Contact",
      "",
      "${2}",
      "",
