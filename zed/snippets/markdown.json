      "",
      "${5}",
      ""
    ],
    "description": "Fiche de créateur"
  },
  "biais": {
    "prefix": "biais",
    "body": [
      "# ${1}",
      "",
      "## Idée fausse",
      "",
      "${3}",
      "",
      "## La réalité",
      "",
      "${4}",
      "",
      "___",
      "",
