{
  "autoUpdatesChannel" : "stable",
  "enabledPlugins" : {
    "agent-skills@addy-agent-skills" : true,
    "rust-analyzer-lsp@claude-plugins-official" : true,
    "typescript-lsp@claude-plugins-official" : true
  },
  "env" : {
    "ENABLE_LSP_TOOL" : "1"
  },
  "extraKnownMarketplaces" : {
    "addy-agent-skills" : {
      "source" : {
        "repo" : "addyosmani\/agent-skills",
        "source" : "github"
      }
    }
  },
  "hooks" : {
    "Notification" : [
      {
        "hooks" : [
          {
            "command" : "python3 ~\/.claude\/hooks\/claude-island-state.py",
            "type" : "command"
          }
        ],
        "matcher" : "*"
      }
    ],
    "PermissionRequest" : [
      {
        "hooks" : [
          {
            "command" : "python3 ~\/.claude\/hooks\/claude-island-state.py",
            "timeout" : 86400,
            "type" : "command"
          }
        ],
        "matcher" : "*"
      }
    ],
    "PostToolUse" : [
      {
        "hooks" : [
          {
            "command" : "python3 ~\/.claude\/hooks\/claude-island-state.py",
            "type" : "command"
          }
        ],
        "matcher" : "*"
      }
    ],
    "PreCompact" : [
      {
        "hooks" : [
          {
            "command" : "python3 ~\/.claude\/hooks\/claude-island-state.py",
            "type" : "command"
          }
        ],
        "matcher" : "auto"
      },
      {
        "hooks" : [
          {
            "command" : "python3 ~\/.claude\/hooks\/claude-island-state.py",
            "type" : "command"
          }
        ],
        "matcher" : "manual"
      }
    ],
    "PreToolUse" : [
      {
        "hooks" : [
          {
            "command" : "python3 ~\/.claude\/hooks\/claude-island-state.py",
            "type" : "command"
          }
        ],
        "matcher" : "*"
      }
    ],
    "SessionEnd" : [
      {
        "hooks" : [
          {
            "command" : "python3 ~\/.claude\/hooks\/claude-island-state.py",
            "type" : "command"
          }
        ]
      }
    ],
    "SessionStart" : [
      {
        "hooks" : [
          {
            "command" : "python3 ~\/.claude\/hooks\/claude-island-state.py",
            "type" : "command"
          }
        ]
      }
    ],
    "Stop" : [
      {
        "hooks" : [
          {
            "command" : "python3 ~\/.claude\/hooks\/claude-island-state.py",
            "type" : "command"
          }
        ]
      }
    ],
    "SubagentStop" : [
      {
        "hooks" : [
          {
            "command" : "python3 ~\/.claude\/hooks\/claude-island-state.py",
            "type" : "command"
          }
        ]
      }
    ],
    "UserPromptSubmit" : [
      {
        "hooks" : [
          {
            "command" : "python3 ~\/.claude\/hooks\/claude-island-state.py",
            "type" : "command"
          }
        ]
      }
    ]
  },
  "minimumVersion" : "2.1.84",
  "permissions" : {
    "allow" : [
      "Bash(bun:*)",
      "WebSearch",
      "Bash(gh issue view:*)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:github.com)",
      "Bash(git add:*)",
      "Bash(git commit -m \"$\\(cat <<''EOF''\nfeat: add Dockerfile and GitLab CI\/CD pipeline\n\nAdd Docker containerization with Deno and persistent SQLite volume.\nAdd GitLab CI pipeline with build and deploy stages.\nUse SQLITE_PATH env var for configurable DB location.\nEOF\n\\)\")",
      "Bash(docker pull:*)",
      "Bash(docker run:*)",
      "Bash(docker stop:*)",
      "Bash(docker build:*)",
      "Bash(curl:*)",
      "Bash(git -C \/Users\/julien\/jclab\/litenote-jetstream log --oneline -20)",
      "Bash(sqlite3:*)",
      "Bash(xargs:*)",
      "Bash(git -C \/Users\/julien\/jclab\/litenote-jetstream show 55699f0 --stat)",
      "Bash(git -C \/Users\/julien\/jclab\/litenote-jetstream show:*)",
      "Bash(git -C \/Users\/julien\/jclab\/litenote-jetstream log --all --full-history -- server.ts)",
      "Bash(deno check:*)"
    ],
    "defaultMode" : "default"
  },
  "statusLine" : {
    "command" : "bash ~\/.claude\/statusline-command.sh",
    "type" : "command"
  },
  "syntaxHighlightingDisabled" : false
}