      "Bash(docker pull:*)",
      "Bash(docker run:*)",
      "Bash(docker stop:*)",
      "Bash(docker build:*)",
      "Bash(curl:*)",
      "Bash(git -C \/Users\/julien\/jclab\/litenote-jetstream log --oneline -20)",
      "Bash(sqlite3:*)",
      "Bash(xargs:*)",
      "Bash(git -C \/Users\/julien\/jclab\/litenote-jetstream show 55699f0 --stat)",
      "Bash(git -C \/Users\/julien\/jclab\/litenote-jetstream show:*)",
      "Bash(git -C \/Users\/julien\/jclab\/litenote-jetstream log --all --full-history -- server.ts)",
      "Bash(deno check:*)"
