{
  "env": {
    "ENABLE_LSP_TOOL": "1"
  },
  "permissions": {
    "allow": [
      "Bash(bun:*)",
      "WebSearch",
      "Bash(gh issue view:*)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:github.com)",
      "Bash(git add:*)",
      "Bash(git commit -m \"$\\(cat <<''EOF''\nfeat: add Dockerfile and GitLab CI/CD pipeline\n\nAdd Docker containerization with Deno and persistent SQLite volume.\nAdd GitLab CI pipeline with build and deploy stages.\nUse SQLITE_PATH env var for configurable DB location.\nEOF\n\\)\")",
      "Bash(docker pull:*)",
      "Bash(docker run:*)",
      "Bash(docker stop:*)",
      "Bash(docker build:*)",
      "Bash(curl:*)",
      "Bash(git -C /Users/julien/jclab/litenote-jetstream log --oneline -20)",
      "Bash(sqlite3:*)",
      "Bash(xargs:*)",
      "Bash(git -C /Users/julien/jclab/litenote-jetstream show 55699f0 --stat)",
      "Bash(git -C /Users/julien/jclab/litenote-jetstream show:*)",
      "Bash(git -C /Users/julien/jclab/litenote-jetstream log --all --full-history -- server.ts)",
      "Bash(deno check:*)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash '/Users/julien/.claude/hooks/herdr-agent-state.sh' blocked",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash '/Users/julien/.claude/hooks/herdr-agent-state.sh' working",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash '/Users/julien/.claude/hooks/herdr-agent-state.sh' release",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash '/Users/julien/.claude/hooks/herdr-agent-state.sh' idle",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash '/Users/julien/.claude/hooks/herdr-agent-state.sh' working",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "agent-skills@addy-agent-skills": true,
    "clangd-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "addy-agent-skills": {
      "source": {
        "source": "github",
        "repo": "addyosmani/agent-skills"
      }
    }
  },
  "syntaxHighlightingDisabled": false,
  "effortLevel": "xhigh",
  "autoUpdatesChannel": "stable",
  "minimumVersion": "2.1.84",
  "skipWorkflowUsageWarning": true,
  "skipAutoPermissionPrompt": true
}
